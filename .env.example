GEMINI_API_KEY=your_gemini_api_key_here

# Image generation (via ImageGen MCP Server)
# Install/run the MCP server separately (recommended) or let the app spawn it.
#
# Option A (recommended): install globally, then set:
# IMAGEGEN_MCP_COMMAND=imagegen-mcp-server
# IMAGEGEN_MCP_ARGS=
#
# Option B: use npx (will download on first run), then set:
# IMAGEGEN_MCP_COMMAND=npx
# IMAGEGEN_MCP_ARGS=-y imagegen-mcp-server
#
# Optional: run the MCP server from a specific folder (where its .env is located)
# IMAGEGEN_MCP_CWD=
# Optional: tool-call timeout
# IMAGEGEN_MCP_TIMEOUT_S=180

# (No image model env needed: app uses Gemini 2.5 Flash Image Preview by default)
